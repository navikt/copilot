# GitHub App credentials (required)
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY=

# BigQuery (required)
GCP_TEAM_PROJECT_ID=

# Server settings
PORT=8080

# Slack notifications (optional - for scan result alerts)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

# Optional overrides
# GITHUB_ORG=navikt
# BIGQUERY_DATASET=copilot_adoption
# BIGQUERY_TABLE=repo_scan
# GRAPHQL_BATCH_SIZE=3
# SCAN_CONCURRENCY=5
# LOG_LEVEL=DEBUG
