{
  "name": "my-copilot",
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build --experimental-build-mode compile",
    "start": "node .next/standalone/server.js",
    "check": "eslint . --fix && tsc --noEmit && prettier --write . --list-different && knip && vitest run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write . --list-different",
    "format:check": "prettier --list-different .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "knip": "knip",
    "generate": "node --experimental-strip-types scripts/generate-manifest.ts"
  },
  "dependencies": {
    "@google-cloud/bigquery": "^8.3.0",
    "@grafana/faro-web-sdk": "^2.5.0",
    "@grafana/faro-web-tracing": "^2.5.0",
    "@headlessui/react": "2.2.10",
    "@icons-pack/react-simple-icons": "^13.13.0",
    "@navikt/aksel-icons": "8.9.1",
    "@navikt/ds-css": "^8.10.4",
    "@navikt/ds-react": "^8.10.4",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/rest": "^22.0.1",
    "@opentelemetry/api": "^1.9.1",
    "@tailwindcss/postcss": "^4.2.4",
    "chart.js": "^4.5.1",
    "gray-matter": "^4.0.3",
    "next": "16.2.3",
    "pino": "^10.3.1",
    "react": "^19.2.6",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "eslint": "~9.39.4",
    "eslint-config-next": "16.2.3",
    "happy-dom": "^20.9.0",
    "knip": "^5.88.1",
    "postcss": "^8.5.14",
    "postcss-load-config": "^6.0.1",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
