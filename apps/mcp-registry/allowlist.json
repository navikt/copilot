{
  "servers": [
    {
      "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
      "name": "io.github.navikt/github-mcp",
      "description": "Access GitHub repositories, issues, and pull requests through secure API integration.",
      "version": "1.0.0",
      "status": "active",
      "publishedAt": "2025-09-01T00:00:00Z",
      "websiteUrl": "https://docs.github.com/en/copilot/customizing-copilot/extending-the-capabilities-of-github-copilot-in-your-organization",
      "repository": {
        "url": "https://github.com/github/github-mcp-server",
        "source": "github"
      },
      "tools": ["get_file_contents", "search_repositories", "create_issue", "list_issues", "create_pull_request", "list_pull_requests", "search_code", "get_commit", "list_commits", "create_branch", "list_branches"],
      "tags": ["developer-tools", "version-control", "github"],
      "remotes": [
        {
          "type": "streamable-http",
          "url": "https://api.githubcopilot.com/mcp/"
        }
      ]
    },
    {
      "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
      "name": "io.github.navikt/mcp-onboarding",
      "description": "Discover Nav Copilot customizations, assess agent readiness, and generate AGENTS.md for your repos.",
      "version": "1.0.0",
      "status": "active",
      "publishedAt": "2025-01-01T00:00:00Z",
      "websiteUrl": "https://github.com/navikt/copilot/tree/main/apps/mcp-onboarding",
      "repository": {
        "url": "https://github.com/navikt/copilot",
        "source": "github",
        "subfolder": "apps/mcp-onboarding"
      },
      "tools": ["hello_world", "greet", "whoami", "echo", "get_time", "list_agents", "list_instructions", "list_prompts", "list_skills", "check_agent_readiness", "generate_agents_md"],
      "tags": ["developer-tools", "onboarding", "nav-internal"],
      "remotes": [
        {
          "type": "streamable-http",
          "url": "https://mcp-onboarding.{{domain_internal}}/mcp"
        }
      ]
    },
    {
      "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
      "name": "com.figma/figma-mcp",
      "description": "Bring Figma design context into your coding workflow for design-to-code generation.",
      "version": "1.0.0",
      "status": "active",
      "publishedAt": "2026-03-05T00:00:00Z",
      "websiteUrl": "https://help.figma.com/hc/en-us/articles/32132100833559-Guide-to-the-Dev-Mode-MCP-Server",
      "repository": {
        "url": "https://github.com/figma/mcp-server-guide",
        "source": "github"
      },
      "tools": ["get_design_context", "get_screenshot", "get_metadata", "get_figjam", "generate_diagram"],
      "tags": ["design", "frontend", "figma"],
      "remotes": [
        {
          "type": "streamable-http",
          "url": "https://mcp.figma.com/mcp"
        }
      ]
    },
    {
      "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
      "name": "com.vercel/next-devtools-mcp",
      "description": "Access Next.js dev server diagnostics, documentation, and upgrade tools.",
      "version": "0.3.10",
      "status": "active",
      "publishedAt": "2026-03-10T00:00:00Z",
      "websiteUrl": "https://nextjs.org/docs/app/guides/mcp",
      "repository": {
        "url": "https://github.com/vercel/next-devtools-mcp",
        "source": "github"
      },
      "tools": ["getErrors", "getRouteInfo", "getDebugInfo", "getDocs"],
      "tags": ["frontend", "nextjs", "developer-tools"],
      "packages": [
        {
          "registryType": "npm",
          "identifier": "next-devtools-mcp",
          "runtimeHint": "node",
          "transport": {
            "type": "stdio"
          },
          "environmentVariables": [
            {
              "name": "NEXT_TELEMETRY_DISABLED",
              "description": "Disable anonymous telemetry to Vercel (set to 1)",
              "isRequired": false,
              "isSecret": false
            }
          ]
        }
      ]
    },
    {
      "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
      "name": "dev.svelte/svelte-mcp",
      "description": "Search Svelte 5 and SvelteKit documentation with static code analysis.",
      "version": "0.1.20",
      "status": "active",
      "publishedAt": "2026-03-10T00:00:00Z",
      "websiteUrl": "https://svelte.dev/docs/mcp",
      "repository": {
        "url": "https://github.com/sveltejs/ai-tools",
        "source": "github",
        "subfolder": "packages/mcp"
      },
      "tools": ["search_docs", "analyze_code"],
      "tags": ["frontend", "svelte", "documentation"],
      "remotes": [
        {
          "type": "streamable-http",
          "url": "https://mcp.svelte.dev/mcp"
        }
      ],
      "packages": [
        {
          "registryType": "npm",
          "identifier": "@sveltejs/mcp",
          "runtimeHint": "node",
          "transport": {
            "type": "stdio"
          }
        }
      ]
    },
    {
      "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
      "name": "com.microsoft/playwright-mcp",
      "description": "Browser automation for UI testing and debugging with network controls.",
      "version": "0.0.68",
      "status": "active",
      "publishedAt": "2026-03-10T00:00:00Z",
      "websiteUrl": "https://www.npmjs.com/package/@playwright/mcp",
      "repository": {
        "url": "https://github.com/microsoft/playwright-mcp",
        "source": "github"
      },
      "tools": ["browser_navigate", "browser_click", "browser_type", "browser_snapshot", "browser_take_screenshot", "browser_wait"],
      "tags": ["testing", "browser-automation", "frontend"],
      "packages": [
        {
          "registryType": "npm",
          "identifier": "@playwright/mcp",
          "runtimeHint": "node",
          "transport": {
            "type": "stdio"
          },
          "packageArguments": [
            {
              "type": "named",
              "name": "--isolated",
              "description": "Run in isolated browser without persistent state"
            },
            {
              "type": "named",
              "name": "--caps",
              "value": "core",
              "description": "Restrict to core capabilities only (no file upload or install)"
            },
            {
              "type": "named",
              "name": "--blocked-origins",
              "value": "*.intern.nav.no,*.intern.dev.nav.no,*.ansatt.nav.no,*.ansatt.dev.nav.no,*.ekstern.dev.nav.no,*.nav.no,*.nais.io,*.adeo.no",
              "description": "Block access to all Nav NAIS ingress domains"
            },
            {
              "type": "named",
              "name": "--block-service-workers",
              "description": "Prevent service worker interception of network requests"
            },
            {
              "type": "named",
              "name": "--save-trace",
              "description": "Enable trace recording for auditability"
            }
          ]
        }
      ]
    }
  ]
}
