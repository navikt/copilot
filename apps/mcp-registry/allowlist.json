    {
      "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
      "name": "io.github.navikt/github-mcp",
      "description": "Access GitHub repositories, issues, and pull requests through secure API integration.",
      "version": "1.0.0",
      "status": "active",
      "publishedAt": "2025-09-01T00:00:00Z",
      "websiteUrl": "https://docs.github.com/en/copilot/customizing-copilot/extending-the-capabilities-of-github-copilot-in-your-organization",
      "repository": {
        "url": "https://github.com/github/github-mcp-server",
        "source": "github"
      },
      "tools": ["get_file_contents", "search_repositories", "create_issue", "list_issues", "create_pull_request", "list_pull_requests", "search_code", "get_commit", "list_commits", "create_branch", "list_branches"],
      "tags": ["developer-tools", "version-control", "github"],
      "examples": [
        {
          "scenario": "Finn kode i et annet repo",
          "prompt": "Søk etter autentiseringsmiddleware i navikt/fp-sak"
        },
        {
          "scenario": "Opprett en issue",
          "prompt": "Opprett en issue i navikt/dp-soknad om å oppgradere Kotlin-versjonen"
        }
      ],
      "remotes": [
        {
          "type": "streamable-http",
          "url": "https://api.githubcopilot.com/mcp/"
        }
      ]
    },
