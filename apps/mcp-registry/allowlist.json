      "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
      "name": "com.vercel/next-devtools-mcp",
      "description": "Access Next.js dev server diagnostics, documentation, and upgrade tools.",
      "version": "0.3.10",
      "status": "active",
      "publishedAt": "2026-03-10T00:00:00Z",
      "websiteUrl": "https://nextjs.org/docs/app/guides/mcp",
      "repository": {
        "url": "https://github.com/vercel/next-devtools-mcp",
        "source": "github"
      },
      "tools": ["getErrors", "getRouteInfo", "getDebugInfo", "getDocs"],
      "tags": ["frontend", "nextjs", "developer-tools"],
      "examples": [
        {
          "scenario": "Feilsøk Next.js-app",
          "prompt": "Vis feil og rute-informasjon fra Next.js dev-serveren i dp-soknad"
        }
      ],
      "packages": [
        {
          "registryType": "npm",
          "identifier": "next-devtools-mcp",
          "runtimeHint": "node",
          "transport": {
            "type": "stdio"
          },
          "environmentVariables": [
            {
              "name": "NEXT_TELEMETRY_DISABLED",
              "description": "Disable anonymous telemetry to Vercel (set to 1)",
              "isRequired": false,
              "isSecret": false
            }
          ]
        }
      ]
    },
