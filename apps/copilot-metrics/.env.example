# GitHub App authentication (required)
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY="FAKE"
GITHUB_APP_INSTALLATION_ID=789

# GitHub scopes
GITHUB_ENTERPRISE_SLUG=nav
GITHUB_ORG=navikt

# GCP / BigQuery (required)
GCP_TEAM_PROJECT_ID=my-project
BIGQUERY_DATASET=copilot_metrics
BIGQUERY_TABLE=usage_metrics

# Slack alerts (optional — no alerts if omitted)
SLACK_WEBHOOK_URL="FAKE"

# Server
PORT=8080
LOG_LEVEL=DEBUG
